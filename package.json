{
  "name": "neon-genesis-evangeli-graph",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:invariants": "vitest run tests/unit/genesis.test.ts tests/unit/graph.test.ts tests/unit/highlight.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "perf": "lhci autorun"
  },
  "dependencies": {
    "astro": "^5.17.0",
    "three": "^0.171.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.6.0",
    "@types/three": "^0.171.0",
    "prettier": "^3.5.0",
    "prettier-plugin-astro": "^0.14.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
