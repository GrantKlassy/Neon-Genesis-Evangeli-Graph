---
/**
 * Opening theme (A Cruel Angel's Thesis). One track ships:
 *
 *   - /sound/theme.opus       original Japanese vocal, 90s TV-size cut
 *                             from the 1995 bluray (extract-theme.sh)
 *
 * The audio element loops the TV-size cut at its own boundary.
 *
 * The mute pill toggles audio. Clicking it is a user gesture and starts
 * playback if it has not started yet.
 *
 * The theme file is baked out of a gitignored source rip (see
 * `task local:assets:bake`) and is itself gitignored --- a clean checkout
 * ships no audio. To keep that case silent (no 404 on load, no console
 * error), the <audio> uses preload="none" and its `src` is assigned lazily
 * on the first playback trigger, never at page load.
 *
 * Playback NEVER starts automatically. There is no muted-autoplay, no
 * resume-from-cookie, no "they granted permission last time" path. The
 * first user gesture (pointerdown or keydown anywhere on the page, or a
 * click on the pill) is the only trigger that starts playback.
 */
---

<audio
  id="ngg-theme-audio"
  data-testid="ngg-theme-audio"
  preload="none"
  playsinline
  loop
  aria-label="Neon Genesis Evangelion opening theme"></audio>

<div
  class="fixed bottom-3 left-3 z-40 flex items-stretch gap-2 sm:bottom-5 sm:left-5"
>
  <button
    type="button"
    id="ngg-theme-toggle"
    data-testid="ngg-theme-toggle"
    data-state="muted"
    class="border border-[color:var(--color-magi-green)]/40 bg-[color:var(--color-panel)]/90 px-3 py-1 font-mono text-[0.6rem] tracking-[0.25em] text-[color:var(--color-magi-green)] uppercase backdrop-blur-sm transition-colors hover:bg-[color:var(--color-panel-2)] sm:text-[0.65rem]"
    aria-pressed="false"
    aria-label="Toggle opening theme audio"
  >
    <span data-theme-label-muted>&#9834; unmute theme</span>
    <span data-theme-label-playing class="hidden">&#9834; mute theme</span>
  </button>
</div>

<script>
  const STORAGE_KEY_MUTED = "ngg.theme.muted";
  const THEME_SRC = "/sound/theme.opus";

  function bootstrap() {
    const audio = document.getElementById(
      "ngg-theme-audio",
    ) as HTMLAudioElement | null;
    const toggle = document.getElementById(
      "ngg-theme-toggle",
    ) as HTMLButtonElement | null;
    if (!audio || !toggle) return;

    const labelMuted = toggle.querySelector<HTMLElement>(
      "[data-theme-label-muted]",
    );
    const labelPlaying = toggle.querySelector<HTMLElement>(
      "[data-theme-label-playing]",
    );
    if (!labelMuted || !labelPlaying) return;

    let savedMuted: string | null = null;
    try {
      savedMuted = localStorage.getItem(STORAGE_KEY_MUTED);
    } catch {
      /* localStorage unavailable; fall back to defaults. */
    }
    const startMuted = savedMuted === "true";

    function paintMute(muted: boolean) {
      toggle!.dataset.state = muted ? "muted" : "playing";
      toggle!.setAttribute("aria-pressed", muted ? "false" : "true");
      labelMuted!.classList.toggle("hidden", !muted);
      labelPlaying!.classList.toggle("hidden", muted);
    }

    function persistMute(muted: boolean) {
      try {
        localStorage.setItem(STORAGE_KEY_MUTED, String(muted));
      } catch {
        /* localStorage unavailable; non-fatal. */
      }
    }

    audio.muted = startMuted;
    paintMute(startMuted);
    // Intentionally no src assignment and no audio.play() here. The source is
    // wired lazily on first playback so a gitignored/absent theme file never
    // 404s on load. Autoplay is forbidden, even muted-autoplay.

    let started = false;
    function startPlayback() {
      if (started) return;
      started = true;
      // Lazily bind the source on the first real playback attempt.
      if (!audio!.getAttribute("src")) audio!.src = THEME_SRC;
      audio!.play().catch(() => {
        // Playback rejected (rare once a gesture has landed, or the theme
        // file is absent); the user can retry by clicking the pill.
        started = false;
      });
    }

    const gestureEvents = ["pointerdown", "keydown"] as const;
    const onFirstGesture = () => {
      startPlayback();
      for (const ev of gestureEvents) {
        document.removeEventListener(ev, onFirstGesture);
      }
    };
    for (const ev of gestureEvents) {
      document.addEventListener(ev, onFirstGesture);
    }

    toggle.addEventListener("click", () => {
      const next = !audio.muted;
      audio.muted = next;
      paintMute(next);
      persistMute(next);
      startPlayback();
    });
  }

  if (
    document.readyState === "complete" ||
    document.readyState === "interactive"
  ) {
    bootstrap();
  } else {
    document.addEventListener("DOMContentLoaded", bootstrap, { once: true });
  }
</script>
