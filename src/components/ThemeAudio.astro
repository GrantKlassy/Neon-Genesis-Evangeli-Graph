---
/**
 * Opening theme (A Cruel Angel's Thesis). Two tracks ship side by side:
 *
 *   - /sound/theme.opus       original Japanese vocal, 90s TV-size cut
 *                             from the 1995 bluray (extract-theme.sh)
 *   - /sound/theme_en.opus    full English cover, externally sourced
 *                             (no English vocal exists in the canon
 *                             bluray --- ADV/Netflix dubs replace
 *                             dialogue only, not the OP)
 *
 * The two tracks differ in length. The audio element loops, so the
 * longer English cover simply loops at its own boundary; nothing in
 * the toggle code assumes equal duration.
 *
 * The mute pill toggles audio. The flag pill switches between languages
 * and persists the choice. Clicking either is a user gesture and starts
 * playback if it has not started yet.
 *
 * Playback NEVER starts automatically. There is no muted-autoplay, no
 * resume-from-cookie, no "they granted permission last time" path. The
 * first user gesture (pointerdown or keydown anywhere on the page, or a
 * click on either pill) is the only trigger that starts playback.
 */
---

<audio
  id="ngg-theme-audio"
  data-testid="ngg-theme-audio"
  preload="auto"
  playsinline
  loop
  aria-label="Neon Genesis Evangelion opening theme"
></audio>

<div class="fixed bottom-3 left-3 z-40 flex items-stretch gap-2 sm:bottom-5 sm:left-5">
  <button
    type="button"
    id="ngg-theme-toggle"
    data-testid="ngg-theme-toggle"
    data-state="muted"
    class="border border-[color:var(--color-magi-green)]/40 bg-[color:var(--color-panel)]/90 px-3 py-1 font-mono text-[0.6rem] tracking-[0.25em] text-[color:var(--color-magi-green)] uppercase backdrop-blur-sm transition-colors hover:bg-[color:var(--color-panel-2)] sm:text-[0.65rem]"
    aria-pressed="false"
    aria-label="Toggle opening theme audio"
  >
    <span data-theme-label-muted>♪ unmute theme</span>
    <span data-theme-label-playing class="hidden">♪ mute theme</span>
  </button>

  <button
    type="button"
    id="ngg-theme-lang-toggle"
    data-testid="ngg-theme-lang-toggle"
    data-lang="jp"
    class="flex items-center justify-center border border-[color:var(--color-magi-green)]/40 bg-[color:var(--color-panel)]/90 px-2 py-1 font-mono text-base leading-none backdrop-blur-sm transition-colors hover:bg-[color:var(--color-panel-2)]"
    aria-label="Switch theme language"
  >
    <span data-theme-flag-jp aria-hidden="true">&#x1F1EF;&#x1F1F5;</span>
    <span data-theme-flag-us class="hidden" aria-hidden="true">&#x1F1FA;&#x1F1F8;</span>
  </button>
</div>

<script>
  const STORAGE_KEY_MUTED = "ngg.theme.muted";
  const STORAGE_KEY_LANG = "ngg.theme.lang";

  type Lang = "jp" | "us";

  const SOURCES: Record<Lang, string> = {
    jp: "/sound/theme.opus",
    us: "/sound/theme_en.opus",
  };

  function isLang(v: unknown): v is Lang {
    return v === "jp" || v === "us";
  }

  function bootstrap() {
    const audio = document.getElementById(
      "ngg-theme-audio",
    ) as HTMLAudioElement | null;
    const toggle = document.getElementById(
      "ngg-theme-toggle",
    ) as HTMLButtonElement | null;
    const langToggle = document.getElementById(
      "ngg-theme-lang-toggle",
    ) as HTMLButtonElement | null;
    if (!audio || !toggle || !langToggle) return;

    const labelMuted = toggle.querySelector<HTMLElement>(
      "[data-theme-label-muted]",
    );
    const labelPlaying = toggle.querySelector<HTMLElement>(
      "[data-theme-label-playing]",
    );
    const flagJp = langToggle.querySelector<HTMLElement>(
      "[data-theme-flag-jp]",
    );
    const flagUs = langToggle.querySelector<HTMLElement>(
      "[data-theme-flag-us]",
    );
    if (!labelMuted || !labelPlaying || !flagJp || !flagUs) return;

    let savedMuted: string | null = null;
    let savedLang: string | null = null;
    try {
      savedMuted = localStorage.getItem(STORAGE_KEY_MUTED);
      savedLang = localStorage.getItem(STORAGE_KEY_LANG);
    } catch {
      /* localStorage unavailable; fall back to defaults. */
    }
    const startMuted = savedMuted === "true";
    const startLang: Lang = isLang(savedLang) ? savedLang : "jp";

    function paintMute(muted: boolean) {
      toggle!.dataset.state = muted ? "muted" : "playing";
      toggle!.setAttribute("aria-pressed", muted ? "false" : "true");
      labelMuted!.classList.toggle("hidden", !muted);
      labelPlaying!.classList.toggle("hidden", muted);
    }

    function paintLang(lang: Lang) {
      langToggle!.dataset.lang = lang;
      flagJp!.classList.toggle("hidden", lang !== "jp");
      flagUs!.classList.toggle("hidden", lang !== "us");
    }

    function persistMute(muted: boolean) {
      try {
        localStorage.setItem(STORAGE_KEY_MUTED, String(muted));
      } catch {
        /* localStorage unavailable; non-fatal. */
      }
    }

    function persistLang(lang: Lang) {
      try {
        localStorage.setItem(STORAGE_KEY_LANG, lang);
      } catch {
        /* localStorage unavailable; non-fatal. */
      }
    }

    audio.muted = startMuted;
    audio.src = SOURCES[startLang];
    paintMute(startMuted);
    paintLang(startLang);
    // Intentionally no audio.play() here. Autoplay is forbidden in this
    // component, even muted-autoplay that browsers would otherwise allow.

    let started = false;
    function startPlayback() {
      if (started) return;
      started = true;
      audio!.play().catch(() => {
        // Playback rejected (rare once a gesture has landed); the user
        // can retry by clicking either pill, which calls this again.
        started = false;
      });
    }

    function setLang(lang: Lang) {
      if (langToggle!.dataset.lang === lang) return;
      const target = SOURCES[lang];
      const wasPlaying = !audio!.paused;
      audio!.pause();
      audio!.src = target;
      audio!.load();
      paintLang(lang);
      persistLang(lang);
      if (wasPlaying || started) {
        audio!.play().catch(() => {
          // The new track may need a fresh user gesture on some browsers
          // if the source change is treated as a new media request.
          started = false;
        });
      }
    }

    const gestureEvents = ["pointerdown", "keydown"] as const;
    const onFirstGesture = () => {
      startPlayback();
      for (const ev of gestureEvents) {
        document.removeEventListener(ev, onFirstGesture);
      }
    };
    for (const ev of gestureEvents) {
      document.addEventListener(ev, onFirstGesture);
    }

    toggle.addEventListener("click", () => {
      const next = !audio.muted;
      audio.muted = next;
      paintMute(next);
      persistMute(next);
      startPlayback();
    });

    langToggle.addEventListener("click", () => {
      const current = (langToggle.dataset.lang as Lang) ?? "jp";
      setLang(current === "jp" ? "us" : "jp");
      startPlayback();
    });
  }

  if (
    document.readyState === "complete" ||
    document.readyState === "interactive"
  ) {
    bootstrap();
  } else {
    document.addEventListener("DOMContentLoaded", bootstrap, { once: true });
  }
</script>
