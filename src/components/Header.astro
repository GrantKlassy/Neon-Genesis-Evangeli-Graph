---
interface Props {
  investigationId: string;
  accountCount: number;
  communityCount: number;
  edgeCount: number;
}

const { investigationId, accountCount, communityCount, edgeCount } =
  Astro.props;
---

<header
  class="border-b border-[color:var(--color-nerv-red)]/30 px-4 pt-6 pb-5 sm:px-8 sm:pt-8 sm:pb-6"
  data-testid="ngg-header"
>
  <div class="mx-auto max-w-6xl">
    <p
      class="font-mono text-[0.65rem] tracking-[0.3em] text-[color:var(--color-magi-green)] uppercase sm:text-xs"
    >
      <span class="text-[color:var(--color-nerv-red)]">NERV</span>
      &middot; magi system &middot; investigation graph &middot; rev. 0
    </p>
    <h1
      class="mt-2 font-bold tracking-tight text-[color:var(--color-nerv-red)] uppercase"
    >
      <span class="block text-2xl leading-none sm:text-4xl lg:text-5xl">
        Neon Genesis
      </span>
      <span
        class="ngg-bracket-red mt-1 block text-3xl leading-none sm:text-5xl lg:text-7xl"
      >
        Evangeli-Graph
      </span>
    </h1>
    <p
      class="mt-3 max-w-2xl text-sm text-[color:var(--color-text-dim)] sm:text-base"
    >
      A three-dimensional reading of the
      <code class="font-mono text-[color:var(--color-magi-green)]"
        >{investigationId}</code
      > investigation. Eight Reddit accounts, six communities, edges colored by relation
      strength. Drag to rotate. Scroll to zoom. Tap a node for the readout.
    </p>
    <dl
      class="mt-4 grid grid-cols-3 gap-2 font-mono text-[0.65rem] tracking-wider uppercase sm:max-w-md sm:text-xs"
    >
      <div
        class="border border-[color:var(--color-nerv-red)]/30 bg-[color:var(--color-panel)] px-3 py-2"
      >
        <dt class="text-[color:var(--color-text-dim)]">accounts</dt>
        <dd
          class="mt-1 text-base text-[color:var(--color-nerv-red)] sm:text-lg"
          data-testid="stat-accounts"
        >
          {accountCount}
        </dd>
      </div>
      <div
        class="border border-[color:var(--color-magi-green)]/30 bg-[color:var(--color-panel)] px-3 py-2"
      >
        <dt class="text-[color:var(--color-text-dim)]">communities</dt>
        <dd
          class="mt-1 text-base text-[color:var(--color-magi-green)] sm:text-lg"
          data-testid="stat-communities"
        >
          {communityCount}
        </dd>
      </div>
      <div
        class="border border-[color:var(--color-eva-orange)]/30 bg-[color:var(--color-panel)] px-3 py-2"
      >
        <dt class="text-[color:var(--color-text-dim)]">edges</dt>
        <dd
          class="mt-1 text-base text-[color:var(--color-eva-orange)] sm:text-lg"
          data-testid="stat-edges"
        >
          {edgeCount}
        </dd>
      </div>
    </dl>
  </div>
</header>
