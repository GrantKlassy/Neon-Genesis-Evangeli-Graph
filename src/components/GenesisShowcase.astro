---
import {
  GENESIS_KINDS,
  genesis,
  shortcodeToSlug,
  shortcodesByKind,
  type GenesisKind,
} from "../genesis";

interface KindGroup {
  id: GenesisKind;
  /** Lowercase suffix used in data-testids for both the legacy palette tests and the new genesis tests. */
  testId: string;
  title: string;
  bracket: "red" | "green";
}

const groups: KindGroup[] = [
  { id: "CHARACTERS", testId: "characters", title: "Characters", bracket: "red" },
  { id: "EVA", testId: "eva", title: "Evangelion Units", bracket: "red" },
  {
    id: "ORGANIZATIONS",
    testId: "organizations",
    title: "Organizations",
    bracket: "green",
  },
  { id: "MAGI", testId: "magi", title: "Magi System", bracket: "green" },
  { id: "ANGELS", testId: "angels", title: "Angels", bracket: "green" },
  { id: "CONCEPTS", testId: "concepts", title: "Concepts", bracket: "green" },
];

// Sanity: every kind in the registry should appear in the groups list.
const _missing = GENESIS_KINDS.filter((k) => !groups.some((g) => g.id === k));
if (_missing.length > 0) {
  throw new Error(
    `genesis showcase missing groups for kinds: ${_missing.join(", ")}`,
  );
}

const totalEntities = Object.keys(genesis).length;
---

<section
  class="mx-auto mt-10 max-w-6xl px-4 pb-12 sm:mt-14 sm:px-8"
  data-testid="ngg-genesis-showcase"
>
  <header class="mb-5">
    <p
      class="font-mono text-[0.65rem] tracking-[0.3em] text-[color:var(--color-magi-green)] uppercase sm:text-xs"
    >
      Genesis &middot; canon &middot; rev. 1
    </p>
    <h2
      class="ngg-bracket-red mt-1 font-mono text-base font-bold tracking-[0.2em] text-[color:var(--color-text)] uppercase sm:text-lg"
    >
      Genesis Mapping
    </h2>
    <p
      class="mt-2 max-w-2xl text-sm text-[color:var(--color-text-dim)] sm:text-base"
    >
      The shortcode registry. {totalEntities} entries spanning <code
        class="font-mono text-[color:var(--color-magi-green)]">CHARACTERS</code
      >, <code class="font-mono text-[color:var(--color-magi-green)]">ANGELS</code>,
      <code class="font-mono text-[color:var(--color-magi-green)]">MAGI</code>,
      <code class="font-mono text-[color:var(--color-magi-green)]">EVA</code>,
      <code class="font-mono text-[color:var(--color-magi-green)]"
        >ORGANIZATIONS</code
      >, and <code class="font-mono text-[color:var(--color-magi-green)]"
        >CONCEPTS</code
      >. Each shortcode has aliases that the page-wide highlighter resolves on
      sight: any text matching <code class="font-mono">"Shinji"</code>,
      <code class="font-mono">"Ikari"</code>, or <code class="font-mono"
        >"Third Child"</code
      > paints in the matching color. Reference colors as
      <code class="font-mono text-[color:var(--color-magi-green)]"
        >var(--genesis-asuka-primary)</code
      > or import <code class="font-mono text-[color:var(--color-magi-green)]"
        >genesis</code
      > from <code class="font-mono">src/genesis</code>.
    </p>
  </header>

  {
    groups.map((group) => {
      const codes = shortcodesByKind(group.id);
      if (codes.length === 0) return null;
      return (
        <div
          class="mt-6"
          data-testid={`genesis-kind-${group.testId}`}
          data-genesis-kind={group.id}
        >
          <h3
            class:list={[
              "font-mono text-xs tracking-[0.2em] uppercase sm:text-sm",
              group.bracket === "red"
                ? "ngg-bracket-red text-[color:var(--color-nerv-red)]"
                : "ngg-bracket-green text-[color:var(--color-magi-green)]",
            ]}
          >
            {group.title}
          </h3>
          <ul class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4">
            {codes.map((code) => {
              const ent = genesis[code];
              const slug = shortcodeToSlug(code);
              return (
                <li
                  class="border border-[color:var(--color-text-dim)]/20 bg-[color:var(--color-panel)] p-3 transition-colors hover:border-[color:var(--color-text-dim)]/45"
                  data-testid={`genesis-entry-${code}`}
                  data-shortcode={code}
                  data-genesis-slug={slug}
                >
                  <div
                    class="flex h-12 overflow-hidden rounded-sm"
                    aria-hidden="true"
                  >
                    <span
                      class="block flex-[3]"
                      style={`background:${ent.primary}`}
                      data-testid={`genesis-primary-${code}`}
                      title={`${ent.displayName} primary ${ent.primary}`}
                    />
                    {ent.secondary.map((c, i) => (
                      <span
                        class="block flex-1 border-l border-black/30"
                        style={`background:${c}`}
                        title={`${ent.displayName} secondary ${i + 1} ${c}`}
                      />
                    ))}
                  </div>
                  <div class="mt-2 flex items-baseline justify-between gap-2">
                    <p class="truncate text-sm font-bold text-[color:var(--color-text)] sm:text-base">
                      {ent.displayName}
                    </p>
                    <p class="font-mono text-[0.6rem] tracking-wider text-[color:var(--color-text-dim)] uppercase">
                      {code}
                    </p>
                  </div>
                  <dl class="mt-1.5 grid grid-cols-[auto_1fr] gap-x-2 gap-y-0.5 font-mono text-[0.65rem] sm:text-xs">
                    <dt class="text-[color:var(--color-text-dim)] uppercase">
                      kind
                    </dt>
                    <dd class="text-[color:var(--color-text)]">{ent.kind}</dd>
                    <dt class="text-[color:var(--color-text-dim)] uppercase">
                      primary
                    </dt>
                    <dd class="text-[color:var(--color-text)]">
                      {ent.primary}
                    </dd>
                    <dt class="text-[color:var(--color-text-dim)] uppercase">
                      aliases
                    </dt>
                    <dd class="text-[color:var(--color-text-dim)]">
                      {ent.aliases.join(" / ")}
                    </dd>
                  </dl>
                  <p class="mt-2 text-[0.7rem] leading-snug text-[color:var(--color-text-dim)] sm:text-xs">
                    {ent.notes}
                  </p>
                </li>
              );
            })}
          </ul>
        </div>
      );
    })
  }
</section>
