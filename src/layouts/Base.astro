---
import "../styles/global.css";
import { paletteAsCssVars } from "../theme/palette";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Neon Genesis Evangeli-Graph --- 3D visualization of the wordword4numbers Reddit account-cluster investigation.",
} = Astro.props;

const paletteCss = paletteAsCssVars();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050507" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link
      rel="preload"
      href="/fonts/inclusive-sans-v4-latin-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/inclusive-sans-v4-latin-700.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <style is:inline>
      @font-face {
        font-family: "Inclusive Sans";
        src: url("/fonts/inclusive-sans-v4-latin-regular.woff2") format("woff2");
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: "Inclusive Sans";
        src: url("/fonts/inclusive-sans-v4-latin-700.woff2") format("woff2");
        font-weight: bold;
        font-style: normal;
        font-display: swap;
      }
    </style>
    <style is:inline set:html={paletteCss} data-testid="ngg-palette-vars"
    ></style>
  </head>
  <body
    class="ngg-grid-bg min-h-screen font-sans antialiased"
    data-testid="ngg-body"
  >
    <slot />
  </body>
</html>
