---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Graph3D from "../components/Graph3D.astro";
import Readout from "../components/Readout.astro";
import { isAccount, isCommunity, wordword4numbers } from "../graph";

const accountCount = wordword4numbers.nodes.filter(isAccount).length;
const communityCount = wordword4numbers.nodes.filter(isCommunity).length;
const edgeCount = wordword4numbers.edges.length;
---

<Base title="Neon Genesis Evangeli-Graph">
  <Header
    investigationId={wordword4numbers.id}
    accountCount={accountCount}
    communityCount={communityCount}
    edgeCount={edgeCount}
  />
  <Graph3D />
  <Readout />
</Base>
